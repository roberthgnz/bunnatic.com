# Supabase
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# Supabase Service Role Key (Required for Stripe Webhooks)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID="UA-XXXXXXXXX-X"

# GOOGLE_PLACES_API_KEY: Required for searching businesses and fetching details
# from Google My Business / Google Maps.
GOOGLE_PLACES_API_KEY="YOUR_GOOGLE_PLACES_API_KEY"

# Firecrawl
# FIRECRAWL_API_KEY: Required for crawling a full website URL in
# /crear-pagina-web-negocio when user enters an http/https URL.
FIRECRAWL_API_KEY="fc-YOUR_FIRECRAWL_API_KEY"

# Upstash Redis
# UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN: Required for rate limiting
# on demo endpoints (/api/demo/places/*). Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://YOUR_REDIS_ENDPOINT.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_TOKEN"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Prices (Price IDs from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRICE_STARTER_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_STARTER_YEARLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_YEARLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_SCALE_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_SCALE_YEARLY="price_..."

# Resend
# RESEND_API_KEY: Required for creating/publishing Resend email templates
RESEND_API_KEY="re_..."
# SEND_EMAIL_HOOK_SECRET: Supabase Auth Email Hook secret
SEND_EMAIL_HOOK_SECRET="v1,whsec_..."
# SENDER_EMAIL: Verified sender in Resend (example: "Bunnatic <no-reply@tudominio.com>")
SENDER_EMAIL="Bunnatic <no-reply@example.com>"
